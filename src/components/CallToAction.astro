---
import svgPinkStar from '../assets/pink-star.svg'
import Button from './Button.astro'
import { buy } from '../sample'

---


<section class="px-3" id="hire">
    <div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)]  relative p-10">
     <h1 class="text-3xl">Let’s start coloborating</h1>
     <p class="text-lg max-w-lg mx-auto">Check my github, connect on LinkedIn, or send me an email for collaboration.</p>
     <div class="flex justify-center gap-4 flex-wrap">
       <Button text={buy.title} link={buy.link} target="_blank" />
       <Button text="LinkedIn" link="https://www.linkedin.com/in/jayasurya-r-b37997279/" target="_blank" />
       <Button text="Email Me" link="mailto:suryasunrise261@gmail.com" />
     </div>
     <img src={svgPinkStar.src} alt="svg" width="80" class="absolute -top-10 right-20 hidden md:block" />
    </div>
  </section>